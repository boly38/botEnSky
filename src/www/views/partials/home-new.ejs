<!-- 
  🏠 BotEnSky Home Page - Modern Design
  Hero, logs timeline, stats dashboard
-->

<div id="logs" class="bes-page-content">


  <!-- Hero Section -->
  <section class="bes-hero scroll-animate">
    <div class="bes-hero-bg"></div>
    <div class="bes-hero-content">
      <h1 class="bes-hero-title">
        <%= __('home.bot_activities') %>
      </h1>
      <p class="bes-hero-description">
        <%= __('home.welcome_on_bot_page') %> 
        <a href="<%- blueskyAccount %>" 
           data-umami-event="bluesky-account"
           class="bes-hero-link">
          @<%- blueskyDisplayName %>
        </a>
        : <%= __('home.a_bluesky_bot') %> 
        <a href="https://nodejs.org/" 
           data-umami-event="nodejs-link"
           class="bes-hero-link">
          Node.js
        </a>
        <sup><%= __('home.version') %><%- version %></sup>
      </p>
      <div class="bes-hero-meta">
        <span><i data-lucide="clock" style="width: 14px; height: 14px;"></i> <%= __('home.freshness') %>: <%- news.to %></span>
        <span><i data-lucide="map-pin" style="width: 14px; height: 14px;"></i> TZ: <%- tz %></span>
      </div>
    </div>
  </section>


  <!-- Activities Section -->
  <section class="glass-card scroll-animate" style="padding: var(--bes-space-6); animation-delay: 200ms;">
    
    <!-- Refresh & Meta -->
    <div class="bes-refresh-section">
      <div style="display: flex; align-items: center; gap: var(--bes-space-3);">
        <a href="/?lang=<%= locale %>" 
           data-umami-event="logs-refresh"
           class="bes-refresh-btn">
          <i data-lucide="refresh-cw" class="bes-refresh-icon"></i>
          <span><%= __('home.activities') %></span>
        </a>
      </div>
      <div class="bes-freshness">
        <i data-lucide="clock"></i> <%= __('home.freshness') %>: <%- news.to %> - TZ: <%- tz %>
      </div>
    </div>

    <!-- Logs Tabs (Date selector) -->
    <nav class="bes-logs-tabs" aria-label="Log dates">
      <% if (news?.data) {
        Object.keys(news.data).forEach((item, index) => { %>
          <a id="logDate-<%- index %>-menu" 
             class="bes-logs-tab" 
             href="#logDate-<%- index %>"
             onclick="window.BesContent.toggleLogDateContent('logDate-<%- index %>', window.logDateIds); return false;"
             data-umami-event="log-date-<%- index %>">
            <%- item %>
          </a>
        <% })
      } %>
      <a id="logDate-week-menu" 
         class="bes-logs-tab" 
         href="#logDate-week"
         onclick="window.BesContent.toggleLogDateContent('logDate-week', window.logDateIds); return false;"
         data-umami-event="log-date-week">
        <%- __('home.seven_days_analytics') %>
      </a>
    </nav>

    <!-- Logs Content -->
    <div class="bes-logs-content">
      
      <!-- Per-date logs -->
      <% if (news?.data) {
        Object.keys(news.data).forEach((item, index) => {
          if (news.data[item].length > 0) { %>
            <div id="logDate-<%- index %>" class="bes-logs-panel">
              <div class="bes-logs-timeline">
                <% news.data[item].forEach(function(newsEntry, entryIndex){ %>
                  <div class="bes-log-entry" style="animation-delay: <%- entryIndex * 50 %>ms;">
                    <div class="bes-log-time"><%- newsEntry.dt %></div>
                    <div class="bes-log-message"><%- newsEntry.message %></div>
                  </div>
                <% }); %>
              </div>
            </div>
          <% }
        })
      } else { %>
        <div class="bes-logs-empty">
          <i data-lucide="inbox"></i>
          <p><%= __('home.no_activity') || 'No activity yet' %></p>
        </div>
      <% } %>

      <!-- 7 days summary -->
      <div id="logDate-week" class="bes-logs-panel">
        
        <!-- Stats Dashboard (7 days) - Horizontal Banner Layout -->
        <div class="bes-stats-section" style="margin-bottom: var(--bes-space-8);">
          <div class="bes-stats-banner">
            <!-- Left: Title (1/3) -->
            <div class="bes-stats-header">
              <h2 class="bes-stats-title">
                <i data-lucide="bar-chart-3"></i>
                <%= __('home.seven_days_analytics') || 'Statistiques sur 7 jours' %>
              </h2>
            </div>

            <!-- Right: Stats (2/3) -->
            <div class="bes-stats-dashboard">
              <div class="bes-stat-card entrance-delay-1">
                <div class="bes-stat-header">
                  <i data-lucide="file-text" class="bes-stat-icon"></i>
                  <span class="bes-stat-label"><%= __('home.posts') %></span>
                </div>
                <div class="bes-stat-value">
                  <a href="https://bsky.app/search?q=from%3Abotensky.bsky.social"
                     class="bes-stat-link"
                     data-umami-event="stats-posts">
                    <%- summary.posts %>
                  </a>
                </div>
              </div>

              <div class="bes-stat-card entrance-delay-2">
                <div class="bes-stat-header">
                  <i data-lucide="heart" class="bes-stat-icon"></i>
                  <span class="bes-stat-label">Likes</span>
                </div>
                <div class="bes-stat-value"><%- summary.likes %></div>
              </div>

              <div class="bes-stat-card entrance-delay-3">
                <div class="bes-stat-header">
                  <i data-lucide="corner-up-left" class="bes-stat-icon"></i>
                  <span class="bes-stat-label">Replies</span>
                </div>
                <div class="bes-stat-value"><%- summary.replies %></div>
              </div>

              <div class="bes-stat-card entrance-delay-4">
                <div class="bes-stat-header">
                  <i data-lucide="repeat" class="bes-stat-icon"></i>
                  <span class="bes-stat-label">Reposts</span>
                </div>
                <div class="bes-stat-value"><%- summary.reposts %></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Best Score Posts -->
        <% if (summary.bestScorePosts && summary.bestScorePosts.length > 0) { %>
          <div class="bes-best-posts-section">
            <h3 class="bes-section-title">
              <i data-lucide="trophy"></i>
              <%= __('home.best_score') %>: <%- summary.bestScore %> (<%- summary.bestScorePosts.length %> posts)
            </h3>
            <div class="bes-best-posts-grid">
              <%- summary.bestScorePostsHtml %>
            </div>
          </div>
        <% } %>

        <!-- Best Likes Posts -->
        <% if (summary.bestLikesPosts && summary.bestLikesPosts.length > 0) { %>
          <div class="bes-best-posts-section">
            <h3 class="bes-section-title">
              <i data-lucide="heart"></i>
              <%= __('home.best_likes') %>: <%- summary.bestLikes %> (<%- summary.bestLikesPosts.length %> posts)
            </h3>
            <div class="bes-best-posts-grid">
              <%- summary.bestLikesPostsHtml %>
            </div>
          </div>
        <% } %>

      </div>

    </div>

  </section>

</div>

<style>
  /* GitHub corner animation (keep original) */
  .bes-github-corner:hover .octo-arm {
    animation: octocat-wave 560ms ease-in-out;
  }
  
  @keyframes octocat-wave {
    0%, 100% { transform: rotate(0); }
    20%, 60% { transform: rotate(-25deg); }
    40%, 80% { transform: rotate(10deg); }
  }
  
  @media (max-width: 500px) {
    .bes-github-corner:hover .octo-arm {
      animation: none;
    }
    .bes-github-corner .octo-arm {
      animation: octocat-wave 560ms ease-in-out;
    }
  }
</style>
